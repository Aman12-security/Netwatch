# ─────────────────────────────────────────────
#  PACKET PARSER
# ─────────────────────────────────────────────
class PacketParser:
    @staticmethod
    def parse_ethernet(raw):
        """Parse Ethernet frame (Linux raw socket)."""
        if len(raw) < 14:
            return None
        dest_mac = PacketParser._format_mac(raw[0:6])
        src_mac  = PacketParser._format_mac(raw[6:12])
        proto    = struct.unpack("!H", raw[12:14])[0]
        return {"dest_mac": dest_mac, "src_mac": src_mac, "proto": proto, "payload": raw[14:]}

    @staticmethod
    def parse_ip(raw):
        """Parse IPv4 header."""
        if len(raw) < 20:
            return None
        ihl    = (raw[0] & 0xF) * 4
        proto  = raw[9]
        src_ip = socket.inet_ntoa(raw[12:16])
        dst_ip = socket.inet_ntoa(raw[16:20])
        ttl    = raw[8]
        length = struct.unpack("!H", raw[2:4])[0]
        return {
            "ihl": ihl, "proto": proto, "src_ip": src_ip,
            "dst_ip": dst_ip, "ttl": ttl, "length": length,
            "payload": raw[ihl:]
        }

    @staticmethod
    def parse_tcp(raw):
        """Parse TCP segment."""
        if len(raw) < 20:
            return None
        src_port, dst_port, seq, ack = struct.unpack("!HHII", raw[0:12])
        offset = ((raw[12] >> 4) * 4)
        flags  = raw[13]
        flags_str = PacketParser._tcp_flags(flags)
        return {
            "src_port": src_port, "dst_port": dst_port,
            "seq": seq, "ack": ack, "flags": flags_str,
            "payload": raw[offset:]
        }

    @staticmethod
    def parse_udp(raw):
        """Parse UDP datagram."""
        if len(raw) < 8:
            return None
        src_port, dst_port, length = struct.unpack("!HHH", raw[0:6])
        return {
            "src_port": src_port, "dst_port": dst_port,
            "length": length, "payload": raw[8:]
        }

    @staticmethod
    def parse_icmp(raw):
        """Parse ICMP message."""
        if len(raw) < 4:
            return None
        icmp_type = raw[0]
        icmp_code = raw[1]
        type_map = {0: "Echo Reply", 3: "Dest Unreachable",
                    8: "Echo Request", 11: "Time Exceeded"}
        return {
            "type": icmp_type, "code": icmp_code,
            "type_name": type_map.get(icmp_type, f"Type {icmp_type}")
        }

    @staticmethod
    def _format_mac(raw):
        return ":".join(f"{b:02x}" for b in raw)

    @staticmethod
    def _tcp_flags(f):
        flags = []
        if f & 0x01: flags.append("FIN")
        if f & 0x02: flags.append("SYN")
        if f & 0x04: flags.append("RST")
        if f & 0x08: flags.append("PSH")
        if f & 0x10: flags.append("ACK")
        if f & 0x20: flags.append("URG")
        return "|".join(flags) if flags else "NONE"


# ─────────────────────────────────────────────
#  STATISTICS TRACKER
# ─────────────────────────────────────────────
class Stats:
    def __init__(self):
        self.total_packets  = 0
        self.total_bytes    = 0
        self.proto_counts   = defaultdict(int)
        self.ip_counts      = defaultdict(int)
        self.port_counts    = defaultdict(int)
        self.alerts         = []
        self.start_time     = time.time()
        self.flagged_ips    = set()

    def record(self, proto_name, src_ip, dst_ip, size, src_port=None, dst_port=None):
        self.total_packets += 1
        self.total_bytes   += size
        self.proto_counts[proto_name] += 1
        self.ip_counts[src_ip] += 1
        if src_port: self.port_counts[src_port] += 1
        if dst_port: self.port_counts[dst_port] += 1

    def add_alert(self, msg):
        ts = datetime.now().strftime("%H:%M:%S")
        self.alerts.append(f"[{ts}] {msg}")

    def elapsed(self):
        return time.time() - self.start_time

    def pps(self):
        e = self.elapsed()
        return self.total_packets / e if e > 0 else 0

    def bps(self):
        e = self.elapsed()
        return (self.total_bytes * 8) / e if e > 0 else 0


